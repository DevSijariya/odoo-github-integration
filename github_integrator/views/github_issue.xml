<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="github_issue_list_view" model="ir.ui.view">
            <field name="name">GitHub Issue</field>
            <field name="model">github.issue</field>
            <field name="arch" type="xml">
                <list>
                    <field name="issue_number"/>
                    <field name="title"/>
                    <field name="state"/>
                    <field name="author_login"/>
                    <field name="created_at"/>
                    <field name="updated_at"/>
                    <field name="linked_task_id"/>
                    <field name="repository_id"/>
                </list>
            </field>
        </record>

        <record id="github_issue_form_view" model="ir.ui.view">
            <field name="name">GitHub Issue</field>
            <field name="model">github.issue</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_open_in_github" string="Open in GitHub" type="object"/>
                        <button name="action_create_task" string="Create Task" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="issue_number"/>
                                <field name="title"/>
                                <field name="state"/>
                                <field name="author_login"/>
                                <field name="repository_id"/>
                                <field name="linked_task_id"/>
                            </group>
                            <group>
                                <field name="created_at"/>
                                <field name="updated_at"/>
                                <field name="issue_url"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
