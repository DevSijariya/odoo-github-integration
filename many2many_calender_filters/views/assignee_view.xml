<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--  Inherit project task calendar view for add filter  -->
    <record id="project_task_calendar_inherit_filters" model="ir.ui.view">
        <field name="name">project.calendar.filters</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_calendar"/>
        <field name="arch" type="xml">
    
            <!-- Remove default assignee -->
            <xpath expr="//field[@name='user_ids']" position="replace"/>
    
            <xpath expr="//calendar" position="inside">
    
                <!-- Project filter -->
                <field name="project_id"
                       filters="1"
                       write_model="project.calendar.filters"
                       write_field="project_id"
                       filter_field="project_checked"
                       options="{'icon': 'fa fa-folder'}"/>
    
                <!-- Assignee filter -->
                <field name="user_ids"
                       filters="1"
                       write_model="project.assignee.filters"
                       write_field="assignee_id"
                       filter_field="assignee_checked"
                       avatar_field="avatar_128"
                       options="{'block': True, 'icon': 'fa fa-users'}"/>
    
            </xpath>
        </field>
    </record>
    
    
</odoo>